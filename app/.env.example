NEXT_PUBLIC_SOLANA_RPC=https://api.mainnet-beta.solana.com
NEXT_PUBLIC_PROGRAM_ID=PhxVau1t1111111111111111111111111111111111
NEXT_PUBLIC_PLATFORM_TREASURY=your-platform-treasury-pubkey
