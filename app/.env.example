DATABASE_URL=postgresql://user:pass@host/db?sslmode=require
JWT_SECRET=generate-a-long-random-secret
CRON_SECRET=generate-another-random-secret

# Phoenix Flight (register once on mainnet)
FLIGHT_FEE_BPS=5
